<%- include("templates/header") %>
<div class="col-12 col-md-10 col-lg-6">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
            <h1 class="h3 fw-semibold mb-2"><%= islogin ? "Log In" : "Sign Up" %></h1>
            <p class="text-body-secondary mb-4"><%= islogin ? "Enter your account details to continue." : "Create a new account to get started." %></p>

            <% if (errMsg) { %>
                <div class="alert alert-danger" role="alert"><%= errMsg %></div>
            <% } %>

            <form action="<%= islogin ? '/loggingin' : '/submitSignup' %>" method="post" class="vstack gap-3">
                <% if (!islogin) { %>
                    <div>
                        <label for="name" class="form-label">Name</label>
                        <input id="name" name="name" type="text" class="form-control" placeholder="Your name" required />
                    </div>
                <% } %>
                <div>
                    <label for="email" class="form-label">Email</label>
                    <input id="email" name="email" type="email" class="form-control" placeholder="name@example.com" required />
                </div>
                <div>
                    <label for="password" class="form-label">Password</label>
                    <input id="password" name="password" type="password" class="form-control" placeholder="Password" required />
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">Submit</button>
            </form>

            <div class="text-center mt-3">
                <% if (islogin) { %>
                    <a class="link-primary" href="/authenticate?type=signup">Don't have an account? Sign up here.</a>
                <% } else { %>
                    <a class="link-primary" href="/authenticate?type=login">Already have an account? Sign in here.</a>
                <% } %>
            </div>
        </div>
    </div>
</div>
<%- include("templates/footer") %>