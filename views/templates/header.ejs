<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous"/>
		<title>Tyson's Cool Website</title>
	</head>
	<body class="d-flex flex-column min-vh-100">
		<header class="d-flex flex-wrap justify-content-center py-3 mb-4 border-bottom">
			<a class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none" href="/">
				<span class="fs-4">Tyson's Cool Website</span>
			</a>
			<ul class="nav nav-pills">
				<li class="nav-item"><a href="/" class="nav-link active" aria-current="page">Home</a></li>
				<% if (locals.authenticated) { %>
					<% if (locals.userType === "admin") { %>
						<li class="nav-item"><a href="/admin" class="nav-link">Admin Dashboard</a></li>
					<% } %>
					<li class="nav-item"><a href="/member" class="nav-link">Member Dashboard</a></li>
					<li class="nav-item"><a href="/logout" class="nav-link">Log out</a></li>
				<% } else { %>
					<li class="nav-item"><a href="/authenticate?type=signup" class="nav-link">Sign-up</a></li>
					<li class="nav-item"><a href="/authenticate?type=login" class="nav-link">Sign-in</a></li>
				<% } %>
			</ul>
		</header>
		<main class="flex-grow-1">
			<section class="container py-5">
				<div class="row justify-content-center">
